# MyTax Malaysia — Environment Variables
# Rename this file to .env and fill in your values
# NEVER commit .env to git

# Firebase (from Firebase Console → Project Settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Anthropic — server-side only, never expose with VITE_ prefix
# Add this in Vercel Dashboard → Project → Settings → Environment Variables
# For local dev: run `vercel dev` instead of `npm run dev`
ANTHROPIC_API_KEY=
